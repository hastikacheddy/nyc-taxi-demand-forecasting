# Copy to .env and fill in. None of these are required for LOCAL development
# (the code falls back to the sqlite MLflow store and the CSV data source).
# In Kubernetes these come from ConfigMaps / Secrets, not a committed file.

# ── MLflow tracking server (Postgres-backed registry) ──────────
# When set, overrides the local sqlite default in config.yaml.
MLFLOW_TRACKING_URI=http://mlflow-server:5000

# ── MinIO (S3-compatible) artifact store ───────────────────────
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── CRM read-only replica (real ingestion source) ──────────────
# Leave MOCK_DATABASE=True to use the local CSV instead.
MOCK_DATABASE=True
RAW_CSV_PATH=
CRM_DB_HOST=
CRM_DB_NAME=
CRM_DB_USER=
CRM_DB_PASSWORD=

# ── Serving API ────────────────────────────────────────────────
API_KEY=
ENV=production
